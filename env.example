# Firebase Configuration (client-safe)
# Get these from your Firebase Console (https://console.firebase.google.com)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here

# Firebase Admin SDK (server-side only, required for /api/summarize to write the shared summary cache)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# External APIs (server-side only — never exposed to the browser)
OPENSTATES_API_KEY=your_openstates_v3_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Shared secret for the AI summary prewarm cron (.github/workflows/prewarm-summaries.yml).
# Generate with: openssl rand -hex 32
# Must match the CRON_SECRET repository *secret* in GitHub Actions.
# If unset, /api/prewarm-summaries returns 404 — the cron is simply disabled.
CRON_SECRET=

# Public site URL — used for metadataBase, sitemap, robots, JSON-LD (set to real production domain in Vercel)
NEXT_PUBLIC_SITE_URL=https://legislation-tracker-inky.vercel.app

# Analytics — set to 'true' only in the production environment.
# Events are written to the Firestore 'analytics_events' collection via /api/track,
# using the Firebase Admin credentials above. There is no third-party analytics service.
NEXT_PUBLIC_ANALYTICS_ENABLED=false
