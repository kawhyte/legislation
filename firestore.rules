rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profiles collection - simplified rules for troubleshooting
    match /users/{userId} {
      // Allow authenticated users to read/write their own documents
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Saved bills subcollection
      match /savedBills/{billId} {
        // Allow authenticated users to read/write their own saved bills
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Global AI summary cache — public read (served to all users), write only via
    // the server (Firebase Admin SDK in /api/summarize), never directly from a client.
    match /bill_summaries/{billId} {
      allow read: if true;
      allow write: if false;
    }

    // Cross-user bill engagement counters (views/saves) feeding the trending score.
    // Public read (the trending feed reads it) and public write, but writes are
    // constrained to the counter fields only. NOTE: these counters are therefore
    // client-inflatable — the trending score caps their weight low, and moving to
    // server-side (Cloud Function) aggregation is a documented follow-up.
    match /billEngagement/{billId} {
      allow read: if true;
      allow write: if request.resource.data.keys()
        .hasOnly(['views', 'saves', 'lastActivityAt', 'title', 'jurisdictionName']);
    }

    // Product analytics events — written only by the server (Admin SDK in
    // /api/track, which bypasses these rules) and read only from the Firebase
    // console. Clients get neither read nor write: an open create rule here
    // would be a spam target, and the events are not user-facing data.
    match /analytics_events/{eventId} {
      allow read, write: if false;
    }

    // Deny access to all other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}